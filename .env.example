# Phoenix OpenTelemetry tracing
# OTLP HTTP endpoint — works through NPM proxy, no gRPC needed
# Default: http://localhost:6006/v1/traces (local dev)
# Production: https://phoenix.ziksaka.com/v1/traces
PHOENIX_COLLECTOR_ENDPOINT=https://phoenix.ziksaka.com/v1/traces
# API key for Phoenix auth (generate in Phoenix UI > Settings > API Keys)
# Required when PHOENIX_ENABLE_AUTH=true on the Phoenix server
PHOENIX_API_KEY=
